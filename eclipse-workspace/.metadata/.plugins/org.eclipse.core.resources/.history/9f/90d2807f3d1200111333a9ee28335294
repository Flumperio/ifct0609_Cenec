package Hilos_2;

import java.util.Scanner;

public class Calculo_IVAs {
    public static void main(String[] args) throws InterruptedException {
        Scanner scanner = new Scanner(System.in);
        double num1;

        // pide usuario dos números y una operación
        System.out.print("Introduce el valor a calcular todos los IVAs: ");
        num1 = scanner.nextDouble();
        new HiloIVA(num1).start();
        scanner.close();
    }
    static class HiloIVA extends Thread {
        // atributos de clase
        private double num1;
        private int iva;
        //constructor
        public HiloResta(double num1) {
            this.num1 = num1;
            this.iva = 7;
        }
        // método run
        public void run() {
            System.out.println("IVA 7%" + (num1 * (iva/100));
        }
    }
}


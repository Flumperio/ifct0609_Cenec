{
  "actions" : {
    "build" : {
      "enabled" : true,
      "script" : "mkdir -p bin\njavac -d bin $(find . -name \"*.java\")"
    },
    "run" : {
      "enabled" : true,
      "script" : "echo \"Ejecutando: ${FileRelativePath}\"\njava -cp bin $(echo ${FileRelativePath} | sed 's\/\\.java$\/\/' | tr '\/' '.')"
    }
  },
  "buildBeforeRunning" : true
}
